# =============================================================================
# FleetOps Maintenance Microservice — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port on which the HTTP server will listen
SERVER_PORT=8080

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL via Supabase)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Supabase-hosted)
# Format: postgres://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgres://your_user:your_password@your_supabase_host:5432/your_database?sslmode=require

# Maximum number of connections in the pool
DATABASE_MAX_CONNS=10

# -----------------------------------------------------------------------------
# Worker Pool Configuration (Bulkhead Pattern)
# -----------------------------------------------------------------------------
# Maximum number of concurrent maintenance workers (goroutines)
# SAD Reference: ADR-5 — Bulkhead Pattern
MAX_WORKERS=5

# Interval in seconds between worker pool queue polling cycles
WORKER_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# Preventive Maintenance Configuration
# -----------------------------------------------------------------------------
# Interval in days between preventive maintenance scheduling runs
CRON_INTERVAL_DAYS=7

# Kilometer threshold: vehicles with >= this value qualify for preventive maintenance
PREVENTIVE_KM_THRESHOLD=10000

# Days threshold: vehicles with >= this many days since last maintenance qualify
PREVENTIVE_DAYS_THRESHOLD=90

# -----------------------------------------------------------------------------
# External Services (Inter-Microservice Communication)
# -----------------------------------------------------------------------------
# Base URL of the Vehicles microservice (accessed via API Gateway)
# SAD Reference: ADR-11 — API Gateway
VEHICLES_SERVICE_URL=http://api-gateway:8000/api/v1/vehiculos
VEHICLES_API_TOKEN=your-jwt-token-here

# HTTP client timeout in seconds for external service calls
HTTP_CLIENT_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Observability (Prometheus)
# -----------------------------------------------------------------------------
# Enable Prometheus metrics endpoint (/metrics)
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_secret

# Messaging (SQS LocalStack)
SQS_QUEUE_URL=http://localstack:4566/000000000000/incidentes-queue
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# -----------------------------------------------------------------------------
# JWT Verification Configuration
# -----------------------------------------------------------------------------
# Encryption algorithm (RS256 is default for public key decryption)
JWT_ALGORITHM=RS256
# Path to the public key PEM file used to verify token signatures
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

