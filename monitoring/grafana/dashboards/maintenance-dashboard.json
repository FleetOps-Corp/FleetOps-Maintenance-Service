{
  "title": "FleetOps Maintenance Service - Go Runtime",
  "uid": "fleetops-go-runtime",
  "schemaVersion": 38,
  "version": 2,
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "go",
    "prometheus",
    "fleetops"
  ],
  "panels": [
    {
      "id": 1,
      "title": "Service Availability",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"fleetops-maintenance\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Resident Memory",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Goroutines",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Heap Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes",
          "legendFormat": "Allocated",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "In Use",
          "refId": "B"
        },
        {
          "expr": "go_memstats_heap_idle_bytes",
          "legendFormat": "Idle",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum[5m]) / rate(go_gc_duration_seconds_count[5m])",
          "legendFormat": "Average pause",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Heap Objects",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "go_memstats_heap_objects",
          "legendFormat": "Objects",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Requests/sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "HTTP Latency p95",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Maintenance Created",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "sum(increase(maintenance_created_total[5m])) by (type)",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Maintenance Errors",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "sum(increase(maintenance_errors_total[5m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Queue Errors",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "increase(maintenance_queue_errors_total[5m])",
          "legendFormat": "Queue Errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Memory Allocation Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "rate(go_memstats_alloc_bytes_total[5m])",
          "legendFormat": "alloc bytes/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "Memory Classes",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "go_memstats_sys_bytes",
          "legendFormat": "Go memory",
          "refId": "A"
        },
        {
          "expr": "go_memstats_stack_inuse_bytes",
          "legendFormat": "Stack",
          "refId": "B"
        },
        {
          "expr": "go_memstats_other_sys_bytes",
          "legendFormat": "Other",
          "refId": "C"
        }
      ]
    },
    {
      "id": 16,
      "title": "File Descriptors",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "Open",
          "refId": "A"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "Max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 17,
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "rate(process_network_receive_bytes_total[5m])",
          "legendFormat": "RX",
          "refId": "A"
        },
        {
          "expr": "rate(process_network_transmit_bytes_total[5m])",
          "legendFormat": "TX",
          "refId": "B"
        }
      ]
    },
    {
      "id": 18,
      "title": "Prometheus Scrapes",
      "type": "timeseries",
      "datasource": "Prometheus",
      targets": [
        {
          "expr": "rate(promhttp_metric_handler_requests_total[5m])",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    }
  ]
}
